{
  "manifest_version": 3,
  "name": "ZendIQ Pro \u2013 Smart Trade Routing",
  "version": "0.7.24",
  "minimum_chrome_version": "104",
  "description": "Solana swap optimiser with MEV protection. Real-time risk scoring on Jupiter, Raydium \u0026 Pump.fun \u2014 before you sign.",
  "homepage_url": "https://zendiq.ai",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.jup.ag/*",
    "https://jup.ag/*",
    "https://*.raydium.io/*",
    "https://raydium.io/*",
    "https://api.mainnet-beta.solana.com/*",
    "https://solana.publicnode.com/*",
    "https://api.rugcheck.xyz/*",
    "https://api.dexscreener.com/*",
    "https://api.geckoterminal.com/*",
    "https://pump.fun/*",
    "https://*.pump.fun/*",
    "https://*.block-engine.jito.wtf/*",
    "https://bundles.jito.wtf/*",
    "https://pumpportal.fun/*",
    "https://zendiq-backend.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://jup.ag/*",
        "https://*.jup.ag/*",
        "https://raydium.io/*",
        "https://*.raydium.io/*",
        "https://pump.fun/*",
        "https://*.pump.fun/*"
      ],
      "js": [
        "scripts/bridge.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://jup.ag/*",
        "https://*.jup.ag/*",
        "https://raydium.io/*",
        "https://*.raydium.io/*",
        "https://pump.fun/*",
        "https://*.pump.fun/*"
      ],
      "js": [
        "scripts/page-config.js",
        "scripts/page-analytics.js",
        "scripts/page-utils.js",
        "scripts/page-sandwich.js",
        "scripts/page-decoders.js",
        "scripts/page-risk.js",
        "scripts/page-token-score.js",
        "scripts/page-wallet.js",
        "scripts/page-security.js",
        "scripts/page-approval.js",
        "scripts/page-widget.js",
        "scripts/page-jito.js",
        "scripts/page-trade.js",
        "scripts/page-network.js",
        "scripts/page-jupiter.js",
        "scripts/page-pump.js",
        "scripts/page-raydium.js",
        "scripts/page-interceptor.js",
        "scripts/page-badge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ZendIQ",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon-48.png"
      ],
      "matches": [
        "https://jup.ag/*",
        "https://*.jup.ag/*",
        "https://raydium.io/*",
        "https://*.raydium.io/*",
        "https://pump.fun/*",
        "https://*.pump.fun/*"
      ]
    }
  ]
}